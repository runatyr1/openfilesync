#!/usr/bin/env bash
# ofs (OpenFileSync) - bidirectional file sync CLI

set -euo pipefail

# Resolve install location
if [[ -L "${BASH_SOURCE[0]}" ]]; then
    REAL_PATH="$(readlink -f "${BASH_SOURCE[0]}")"
else
    REAL_PATH="${BASH_SOURCE[0]}"
fi
BIN_DIR="$(cd "$(dirname "$REAL_PATH")" && pwd)"
LIB_DIR="${BIN_DIR}/../lib"

source "${LIB_DIR}/core.sh"
source "${LIB_DIR}/sync.sh"
source "${LIB_DIR}/filters.sh"
source "${LIB_DIR}/health.sh"

VERSION="0.1.0"

usage() {
    cat <<EOF
ofs v${VERSION} - OpenFileSync - bidirectional file sync

Usage: ofs <command> [options]

Commands:
  init              Setup wizard (configure remote, folders, first sync)
  sync              Run sync once
  sync --dry-run    Preview sync without changes
  sync --resync     Force full resync (after config changes)
  status            Show sync status and health
  conflicts         List conflict files
  log               Tail the sync log
  update            Update ofs to latest version
  install-service   Install systemd timer
  stop-service      Stop systemd timer
  restart-service   Restart systemd timer
  uninstall-service Remove systemd timer
  help              Show this help
  version           Show version

EOF
}

# --- Init wizard ---

cmd_init() {
    ensure_dirs
    echo "OpenFileSync Setup"
    echo "=================="
    echo ""

    # 1. SFTP connection
    echo "-- Remote Storage (SFTP) --"
    read -rp "Host (e.g. uXXXXXX.your-storagebox.de): " host
    read -rp "Port [23]: " port
    port="${port:-23}"
    read -rp "Username: " user

    echo "Auth method:"
    echo "  1) Password"
    echo "  2) SSH key"
    read -rp "Choice [1]: " auth_choice
    auth_choice="${auth_choice:-1}"

    local remote_name="openfilesync"

    # Remove existing rclone remote if present
    rclone config delete "$remote_name" 2>/dev/null || true

    if [[ "$auth_choice" == "2" ]]; then
        read -rp "SSH key path [~/.ssh/id_rsa]: " key_path
        key_path="${key_path:-${HOME}/.ssh/id_rsa}"
        rclone config create "$remote_name" sftp \
            host "$host" port "$port" user "$user" \
            key_file "$key_path" \
            shell_type none
    else
        read -rsp "Password: " password
        echo ""
        rclone config create "$remote_name" sftp \
            host "$host" port "$port" user "$user" \
            pass "$(rclone obscure "$password")" \
            shell_type none
    fi

    echo ""
    echo "Testing connection..."
    if rclone lsd "${remote_name}:" >/dev/null 2>&1; then
        echo "Connected successfully."
    else
        echo "Connection failed. Check your credentials and try again."
        rclone config delete "$remote_name" 2>/dev/null || true
        return 1
    fi

    REMOTE="$remote_name"
    echo ""

    # 2. Folder selection
    echo "-- Folders to Sync --"
    echo "  1) Specify local folders to sync (first machine / new setup)"
    echo "  2) Browse remote and pick existing folders (second machine / restore)"
    echo "  3) Cancel"
    read -rp "Choice [1]: " folder_mode
    folder_mode="${folder_mode:-1}"

    MAPPING_REMOTES=()
    MAPPING_LOCALS=()

    if [[ "$folder_mode" == "3" ]]; then
        echo "Cancelled."
        return 0
    elif [[ "$folder_mode" == "2" ]]; then
        # Browse remote directories
        echo ""
        echo "Fetching remote directories..."
        local remote_dirs
        remote_dirs="$(rclone lsd "${remote_name}:" 2>/dev/null | awk '{print $NF}' || true)"

        if [[ -z "$remote_dirs" ]]; then
            echo "No directories found on remote. Use option 1 instead."
            return 1
        fi

        echo ""
        echo "Available remote directories:"
        local dir_list=()
        local idx=1
        while IFS= read -r dir; do
            dir_list+=("$dir")
            echo "  ${idx}) ${dir}"
            ((idx++))
        done <<< "$remote_dirs"
        echo "  a) Sync all"
        echo ""

        read -rp "Select directories (comma-separated numbers, or 'a' for all): " selection

        local selected=()
        if [[ "$selection" == "a" ]]; then
            selected=("${dir_list[@]}")
        else
            IFS=',' read -ra picks <<< "$selection"
            for pick in "${picks[@]}"; do
                pick="$(echo "$pick" | xargs)"
                if [[ "$pick" =~ ^[0-9]+$ ]] && (( pick >= 1 && pick <= ${#dir_list[@]} )); then
                    selected+=("${dir_list[$((pick-1))]}")
                else
                    echo "  Skipping invalid selection: ${pick}"
                fi
            done
        fi

        if [[ ${#selected[@]} -eq 0 ]]; then
            echo "No directories selected. Exiting."
            return 1
        fi

        for remote_path in "${selected[@]}"; do
            local local_path="${HOME}/${remote_path}"
            echo "  Remote: ${remote_path} -> Local: ${local_path}"
            read -rp "    Custom local path? [Enter to accept]: " custom_local
            local_path="${custom_local:-$local_path}"
            local_path="${local_path/#\~/$HOME}"

            MAPPING_REMOTES+=("$remote_path")
            MAPPING_LOCALS+=("$local_path")
            echo "    Added: ${local_path} <-> ${REMOTE}:${remote_path}"
        done
    else
        # Specify local folders
        echo ""
        echo "Enter paths one per line, or paste multiple at once."
        echo "Press Enter on empty line when done."
        echo ""
        echo "Examples:"
        echo "  ${HOME}/Documents"
        echo "  ${HOME}/Projects"
        echo "  ${HOME}/.bashrc"
        echo "  ${HOME}/.config/nvim"
        echo ""

        add_path() {
            local local_path="$1"

            # Trim whitespace
            local_path="$(echo "$local_path" | xargs)"
            [[ -z "$local_path" ]] && return 1

            # Expand ~ to $HOME
            local_path="${local_path/#\~/$HOME}"

            if [[ ! -e "$local_path" ]]; then
                echo "  Warning: path does not exist yet (will be created on first sync)"
            fi

            # Auto-generate remote path: strip $HOME prefix
            local remote_path
            remote_path="${local_path#"$HOME"}"
            remote_path="${remote_path#/}"

            MAPPING_REMOTES+=("$remote_path")
            MAPPING_LOCALS+=("$local_path")
            echo "  Added: ${local_path} <-> ${REMOTE}:${remote_path}"
        }

        while true; do
            read -rp "Path (or empty to finish): " local_path
            [[ -z "$local_path" ]] && break

            add_path "$local_path"

            # Drain any remaining lines from a pasted block
            while read -r -t 0.1 extra_line; do
                [[ -z "$extra_line" ]] && continue
                add_path "$extra_line"
            done

            echo ""
        done
    fi

    if [[ ${#MAPPING_REMOTES[@]} -eq 0 ]]; then
        echo "No folders selected. Exiting."
        return 1
    fi

    # 3. Save config and mappings
    SYNC_INTERVAL="${DEFAULT_SYNC_INTERVAL}"
    CONFLICT_RESOLVE="${DEFAULT_CONFLICT_RESOLVE}"
    MAX_DELETE="${DEFAULT_MAX_DELETE}"
    save_config
    save_mappings
    echo ""
    echo "Config saved to ${CONFIG_FILE}"
    echo "Mappings saved to ${MAPPINGS_FILE}"

    # 4. Build filters (all presets enabled by default)
    build_filters
    echo ""

    # 5. Dry run preview
    echo "-- Preview (dry run) --"
    echo ""
    run_sync "true" "true"
    echo ""

    read -rp "Looks good? Run initial sync now? [Y/n]: " confirm
    confirm="${confirm:-Y}"

    if [[ "$confirm" =~ ^[Yy] ]]; then
        echo ""
        echo "Running initial sync (this may take a while for large folders)..."
        run_sync "false" "true"
        echo ""

        # 6. Install systemd timer
        read -rp "Install systemd timer (sync every 30 min)? [Y/n]: " install_timer
        install_timer="${install_timer:-Y}"
        if [[ "$install_timer" =~ ^[Yy] ]]; then
            cmd_install_service
        fi
    else
        echo ""
        echo "Skipped. Run 'ofs sync --resync' when ready."
    fi

    echo ""
    echo "Setup complete. Syncing ${#MAPPING_REMOTES[@]} folder(s) every 30 min."
    echo "Run 'ofs status' anytime to check."
}

# --- Service management ---

SYSTEMD_DIR="${HOME}/.config/systemd/user"

cmd_install_service() {
    mkdir -p "$SYSTEMD_DIR"

    cat > "${SYSTEMD_DIR}/ofs-sync.service" << EOF
[Unit]
Description=OpenFileSync - bidirectional file sync
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
ExecStart=$(command -v ofs || echo "${BIN_DIR}/ofs") sync
StandardOutput=null
StandardError=journal
EOF

    cat > "${SYSTEMD_DIR}/ofs-sync.timer" << EOF
[Unit]
Description=OpenFileSync - scheduled sync timer

[Timer]
OnBootSec=5min
OnUnitActiveSec=30min
RandomizedDelaySec=60

[Install]
WantedBy=timers.target
EOF

    systemctl --user daemon-reload
    systemctl --user enable --now ofs-sync.timer

    echo "Systemd timer installed and started."
    echo "Check with: systemctl --user status ofs-sync.timer"
}

cmd_stop_service() {
    systemctl --user stop ofs-sync.timer 2>/dev/null || true
    echo "Systemd timer stopped."
}

cmd_restart_service() {
    systemctl --user restart ofs-sync.timer
    echo "Systemd timer restarted."
    systemctl --user status ofs-sync.timer --no-pager
}

cmd_uninstall_service() {
    systemctl --user disable --now ofs-sync.timer 2>/dev/null || true
    rm -f "${SYSTEMD_DIR}/ofs-sync.service" "${SYSTEMD_DIR}/ofs-sync.timer"
    systemctl --user daemon-reload
    echo "Systemd timer removed."
}

# --- Log ---

cmd_log() {
    if [[ -f "$LOG_FILE" ]]; then
        tail -f "$LOG_FILE"
    else
        echo "No log file yet. Run 'ofs sync' first."
    fi
}

# --- Update ---

cmd_update() {
    echo "Updating OpenFileSync..."
    curl -fsSL -H "Cache-Control: no-cache" "https://get.openfilesync.runatyr.dev/?t=$(date +%s)" | bash
}

# --- Main dispatcher ---

main() {
    local cmd="${1:-}"
    shift || true

    case "$cmd" in
        init)
            cmd_init
            ;;
        sync)
            local dry_run="false"
            local resync="false"
            for arg in "$@"; do
                case "$arg" in
                    --dry-run)  dry_run="true" ;;
                    --resync)   resync="true" ;;
                esac
            done
            ensure_dirs
            trim_log
            build_filters
            run_sync "$dry_run" "$resync"
            ;;
        status)
            show_status
            ;;
        conflicts)
            list_conflicts
            ;;
        install-service)
            cmd_install_service
            ;;
        stop-service)
            cmd_stop_service
            ;;
        restart-service)
            cmd_restart_service
            ;;
        uninstall-service)
            cmd_uninstall_service
            ;;
        log)
            cmd_log
            ;;
        update)
            cmd_update
            ;;
        version|--version|-v)
            echo "ofs v${VERSION} (OpenFileSync)"
            ;;
        help|--help|-h|"")
            usage
            ;;
        *)
            echo "Unknown command: $cmd"
            echo ""
            usage
            return 1
            ;;
    esac
}

main "$@"
